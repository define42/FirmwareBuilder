#!/bin/sh

case "$1" in
  start)
    if command -v rauc >/dev/null 2>&1; then
      if mountpoint -q /efi && mountpoint -q /data; then
        mkdir -p /data/rauc
        rauc status mark-good || true
      else
        echo "Skipping RAUC mark-good because /efi or /data is not mounted"
      fi
    fi
    ;;
  stop)
    ;;
  restart)
    ;;
esac
